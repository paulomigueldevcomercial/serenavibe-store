# Configuracao legada para deploy standalone com Caddy.
# Neste servidor, o host store.serenavibe.com.br fica no nginx principal
# de goldeplaca-projeto e aponta para serenavibe-wordpress:80.
{
    email store@serenavibe.com.br
}

store.serenavibe.com.br {
    encode gzip
    reverse_proxy wordpress:80
}

www.store.serenavibe.com.br {
    redir https://store.serenavibe.com.br{uri}
}
